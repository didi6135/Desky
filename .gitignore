# Operator-local planning notes and scripts — never push
# (token-bearing, environment-specific, or otherwise personal)
.planning/LOCAL*

# Build output (regenerated by build.sh)
# We DO commit dist/install.sh — it's the file curl serves to end users.
# Other dist/ artifacts (logs, partial files) stay ignored.
dist/*
!dist/install.sh

# Deploy logs (Phase 1.6)
logs/
*.log

# Env files — never commit secrets
.env
.env.*
!.env.example

# SSH artifacts (paranoia)
*.pem
*.key
id_rsa*
id_ed25519*

# OS junk
.DS_Store
Thumbs.db
desktop.ini
*~

# Editors
.vscode/
.idea/
*.swp
*.swo

# Node (future-proofing)
node_modules/
npm-debug.log*

# Bun + TS build output
bun.lockb
src/dist/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
